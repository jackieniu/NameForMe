# ========== 大模型（OpenAI 兼容 Chat Completions，三个均必填）==========
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# ========== 域名检测（二选一或都配）==========
# 阿里云万网（推荐国内用户）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Namecheap（海外用户）
# NAMECHEAP_API_USER=
# NAMECHEAP_API_KEY=
# NAMECHEAP_CLIENT_IP=

# ========== 站点与可选 ==========
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Turnstile（机器人防护，https://developers.cloudflare.com/turnstile/）
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Namecheap Affiliate（注册跳转推广参数）
# NAMECHEAP_AFFILIATE_ID=

# ========== 限流（可选，生产建议配置）==========
# Upstash Redis：在 https://console.upstash.com 创建后复制 REST URL 与 Token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
