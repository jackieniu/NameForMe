# ========== 大模型（OpenAI 兼容 Chat Completions，三个均必填）==========
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# DeepSeek 思考模式：不设或 false 时，对「须返回 JSON」的补全（域名精炼/打分）会在请求中关闭 thinking，避免与 json_object 解析混叠。设为 true 则不在此处关闭（更慢、JSON 易出错）。
# LLM_DEEPSEEK_THINKING=true

# ========== 域名检测（至少配置一套：Cloudflare Registrar / 阿里云）==========
# Cloudflare Registrar API（批量检测 + USD at-cost 定价，与站点托管无关）
# CF_REGISTRAR_TOKEN=
# CF_ACCOUNT_ID=

# 阿里云万网
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# ========== 站点与可选 ==========
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 阿里云万网跳转云大使（可选；不设则使用代码内默认，便于 fork 自部署仍带推广）
# ALIYUN_WANWANG_SOURCE=
# ALIYUN_WANWANG_USER_CODE=

# Turnstile（机器人防护，https://developers.cloudflare.com/turnstile/）
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ========== 限流（可选，生产建议配置）==========
# Upstash Redis：在 https://console.upstash.com 创建后复制 REST URL 与 Token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
