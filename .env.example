# ========== 大模型（OpenAI 兼容 Chat Completions，三个均必填）==========
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ========== 域名检测（二选一或都配）==========
# 阿里云万网（推荐国内用户）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Namecheap（海外用户）
# NAMECHEAP_API_USER=
# NAMECHEAP_API_KEY=
# NAMECHEAP_CLIENT_IP=

# ========== 站点与可选 ==========
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile（机器人防护）
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Namecheap Affiliate（注册跳转推广参数）
# NAMECHEAP_AFFILIATE_ID=

# Cloudflare Pages 限流：KV + D1 绑定不写在本文件；创建资源、填 wrangler.toml、
# 或在 Pages → Settings → Functions → Bindings 绑定，见 docs/cloudflare-deploy.md
