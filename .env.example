# ========== 大模型（OpenAI 兼容 Chat Completions）==========
# 密钥（三选一，优先级从左到右）
LLM_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# 可选：API 基址（须可接 OpenAI 兼容路径 /v1/chat/completions；未写 /v1 会自动补）
# 默认：https://api.deepseek.com/v1
# LLM_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：模型 ID（默认 deepseek-chat）
# LLM_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini

# ========== 域名检测（二选一或都配）==========
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# NAMECHEAP_API_USER=
# NAMECHEAP_API_KEY=
# NAMECHEAP_CLIENT_IP=

# ========== 站点与可选 ==========
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Cloudflare Pages 限流（部署到 CF 并创建资源后填写）
# （在 Pages 控制台绑定 KV namespace BLOCKLIST 与 D1 DB，无需写进本文件）
